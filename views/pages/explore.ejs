<% layout('layouts/boilerplate') %>

<div class="<%= config.pattern %>">
    <section class="relative px-8 md:px-20 py-16 md:py-24 max-w-screen-2xl mx-auto overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            <div class="lg:col-span-7 z-10">
                <span class="inline-block px-4 py-1.5 bg-primary-container/20 text-primary rounded-full text-xs font-bold tracking-[0.2em] uppercase mb-8">Sacred Architecture</span>
                <h1 class="font-headline font-black text-6xl md:text-8xl text-on-surface leading-[1.1] mb-8 tracking-tighter">
                    <%= config.title %> <br/><span class="text-transparent bg-clip-text bg-gradient-to-r <%= config.gradient %>"><%= config.accent %></span>
                </h1>
                <p class="font-body text-xl text-on-surface-variant leading-relaxed max-w-2xl mb-12">
                    Explore the celestial geometry and timeless devotion woven into the stone of India's most revered sanctuaries.
                </p>
            </div>
        </div>
    </section>

    <section class="px-8 md:px-20 py-20 bg-surface-container-low/50">
        <div class="max-w-screen-2xl mx-auto">
            <div class="space-y-32">
                <% for(let region of regionData) { %>
                    <div class="space-y-12">
                        <div class="border-b border-outline-variant/20 pb-8">
                            <h2 class="font-headline text-4xl font-bold text-on-surface"><%= region.name %></h2>
                            <p class="text-on-surface-variant mt-2 font-body italic"><%= region.description %></p>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                            <% for(let site of region.sites) { %>
                                <div class="group bg-white rounded-lg overflow-hidden shadow-sm hover:translate-y-[-8px] transition-all duration-300">
                                    <div class="relative h-72 overflow-hidden">
                                        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="<%= site.image %>" alt="<%= site.name %>">
                                        <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-primary"><%= site.location %></div>
                                    </div>
                                    <div class="p-8">
                                        <h3 class="font-headline text-2xl font-bold mb-2"><%= site.name %></h3>
                                        <div class="flex items-center gap-2 text-on-surface-variant text-sm mb-6">
                                            <span><%= site.hours %></span>
                                        </div>
                                        <button class="w-full py-4 rounded-full border border-primary/20 text-primary font-bold hover:bg-primary hover:text-white transition-all duration-300">
                                            Explore
                                        </button>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</div>