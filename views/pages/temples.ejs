<% layout('layouts/boilerplate') %>

    <style>
        /* Fixed Background Layer */
        .page-bg-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            overflow: hidden;
        }

        .page-bg-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.85);
        }

        .hero-gradient-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0) 100%);
            z-index: -1;
        }

        .page-wrapper {
            position: relative;
            z-index: 1;
        }
    </style>

    <div class="page-bg-container">
        <div class="hero-gradient-overlay"></div>
    </div>

    <div class="page-wrapper">
        <section class="px-6 pt-20 pb-12 md:px-12 lg:px-24 relative overflow-hidden">
            <div class="flex flex-col md:flex-row items-center justify-between gap-12">
                <div class="w-full md:w-5/12">
                    <span class="text-xs font-bold tracking-widest uppercase text-gray-700">Sacred Architecture</span>
                    <h1 class="mt-4 text-6xl md:text-8xl font-black leading-tight text-black">
                        Temples of <br>
                        <span class="text-[#FF9933]">Bharat</span>
                    </h1>
                    <p class="mt-8 max-w-2xl text-xl text-gray-900 leading-relaxed font-medium">
                        Discover the towering Gopurams, intricate stone carvings, and the ancient spiritual energy woven
                        into the heart of India.
                    </p>
                </div>

                <div class="w-full md:w-7/12 relative flex justify-center items-center md:pl-12">
                    <div class="carousel-container !h-[450px] md:!h-[500px] justify-center w-full">
                        <div id="carousel-track" class="carousel-track"></div>
                    </div>
                    <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-orange-500/10 rounded-full blur-3xl -z-10">
                    </div>
                </div>
            </div>
        </section>

        <div class="container mx-auto px-4 py-12 max-w-[1800px]">
            <% (typeof templeData !=='undefined' ? templeData : []).forEach(item=> { %>
                <div class="mb-16">
                    <div
                        class="flex items-center gap-4 mb-8 border-b border-black/10 pb-2 backdrop-blur-sm bg-white/30 rounded-t-lg px-4">
                        <i class="fa-solid fa-location-dot text-[#FF9933] text-2xl"></i>
                        <h2 class="font-display text-3xl font-bold text-black">
                            <%= item.state %>
                        </h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                        <% (item.churches || item.sites || item.temples || item.data || []).forEach(temple=> { %>

                            <div
                                class="bg-white/90 backdrop-blur-md rounded-[40px] p-4 shadow-xl border border-white/20 flex flex-col items-center text-center transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 h-full w-full">

                                <div class="relative w-full h-60 mb-4 overflow-hidden rounded-[28px]">
                                    <% if(temple.image && temple.image !=="/" && temple.image !=="" ) { %>
                                        <img src="<%= temple.image %>" alt="<%= temple.title || temple.name %>"
                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                                        <% } else { %>
                                            <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                                <i class="fa-solid fa-om text-5xl text-gray-300"></i>
                                            </div>
                                            <% } %>

                                                <div
                                                    class="absolute top-4 right-4 z-10 bg-white/40 backdrop-blur-md px-4 py-2 rounded-full shadow-md border border-white/30 min-w-[80px] flex items-center justify-center transition-transform hover:scale-105">
                                                    <span
                                                        class="text-gray-950 text-[14px] font-bold tracking-tight flex items-center justify-center gap-1.5 card-city capitalize">
                                                        <span>
                                                            <%= temple.city || temple.location %>
                                                        </span>
                                                    </span>
                                                </div>
                                </div>

                                <div class="w-full px-2 flex flex-col flex-grow">
                                    <div class="flex items-start justify-center gap-2 mb-2">
                                        <h3 class="text-lg font-black text-black tracking-tight leading-tight"
                                            style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 23px;">
                                            <%= temple.title || temple.name %>
                                        </h3>
                                    </div>

                                    <p class="text-gray-600 text-xs leading-relaxed mb-4 flex-grow line-clamp-2"
                                        style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 15px;">
                                        <%= temple.description %>
                                    </p>

                                    <div class="flex justify-center items-center border-t border-gray-100 pt-3 mb-4">
                                        <div class="px-3 text-center">
                                            <div class="text-black font-bold text-sm leading-snug"
                                                style="font-family: 'Plus Jakarta Sans', sans-serif;">
                                                <%- (temple.timing || temple.hours || "" ).replace('&', '<br>' ) %>
                                            </div>
                                            <div
                                                class="text-[12px] uppercase tracking-widest text-gray-400 font-bold mt-1">
                                                Visiting Hours</div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-3 w-full mt-auto">
                                        <button
                                            onclick="openTempleModal('<%= temple.title || temple.name %>', '<%= temple.image %>', '<%= temple.city || temple.location %>', `<%= temple.description %>`, '<%= temple.locIcon %>', '<%= temple.timing || temple.hours %>')"
                                            class="flex-grow bg-white text-black border border-gray-200 py-3 rounded-full font-bold text-xs flex items-center justify-center gap-2 hover:bg-black hover:text-white transition-all duration-300 no-underline shadow-sm">
                                            <i class="fa-regular fa-envelope text-base"></i>
                                            <span>Read More</span>
                                        </button>

                                        <a href="<%= temple.locIcon || '#' %>" target="_blank"
                                            class="bg-black/10 backdrop-blur-md text-black border border-black/5 h-[44px] w-[44px] rounded-[14px] flex items-center justify-center hover:bg-black/20 transition-all shrink-0 no-underline">
                                            <i class="fa-solid fa-location-dot text-lg"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <% }) %>
                    </div>
                </div>
                <% }) %>
        </div>


        <!--Complete detail card-->

        <div id="templeModal"
            class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
            <div
                class="bg-white rounded-[40px] w-full max-w-[1100px] flex flex-col md:flex-row overflow-hidden shadow-2xl relative animate-pop-in">
                <button onclick="closeTempleModal()"
                    class="absolute top-6 right-6 z-50 text-gray-400 hover:text-black text-2xl">&times;</button>

                <div class="w-full md:w-[45%] relative h-[300px] md:h-[650px]">
                    <img id="modalImage" src="" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>

                    <div
                        class="absolute top-8 right-8 z-10 bg-white/100 backdrop-blur-md px-4 py-1.5 rounded-full text-15px font-bold border border-white/30 text-orange-400 font-family:'Plus Jakarta Sans', sans-serif;">
                        <i class="fa-solid fa-location-dot mr-2 text-[#FF9933]"></i><span
                            id="modalLocationLabel"></span>
                    </div>

                    <div class="absolute bottom-10 left-10 text-white">
                        <h2 id="modalTitle" class="text-5xl font-bold leading-tight mb-2"></h2>
                        <div class="flex items-center gap-4 text-sm opacity-90">
                            <span><i class="fa-solid fa-om mr-2"></i><span id="modalDeity">Lord Shiva</span></span>
                            <span class="opacity-50">|</span>
                            <span id="modalSignificance">Ancient Jyotirlinga</span>
                        </div>
                    </div>
                </div>

                <div class="w-full md:w-[55%] p-8 md:p-12 flex flex-col justify-between bg-white">
                    <div>
                        <div class="flex justify-between items-start mb-10">
                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400 mb-1">
                                    Pilgrimage Pulse</p>
                                <h3 class="text-2xl font-bold text-gray-800">Heritage Details</h3>
                            </div>
                            <div class="flex gap-8">
                                <div class="text-center">
                                    <span class="text-green-500 text-[10px] font-bold">● LIVE</span>
                                    <p class="text-xl font-bold">12.4k</p>
                                    <span class="text-[10px] text-gray-400">VISITORS</span>
                                </div>
                                <div class="text-center">
                                    <span class="text-gray-400 text-[10px] font-bold">🕒 WAIT</span>
                                    <p class="text-xl font-bold">45m</p>
                                    <span class="text-[10px] text-gray-400">AVERAGE</span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="w-8 h-8 rounded-full bg-orange-50 flex items-center justify-center">
                                    <i class="fa-solid fa-wand-magic-sparkles text-orange-400 text-sm"></i>
                                </div>
                                <h4 class="font-bold text-lg">Divine Essence</h4>
                            </div>
                            <p id="modalDescription" class="text-gray-600 leading-relaxed text-sm"></p>
                        </div>
                        <hr>

                        <div class="grid grid-cols-2 gap-y-8 border-t border-gray-100 pt-8">
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">
                                    Architecture</p>
                                <p id="modalArchitecture" class="font-bold text-gray-800">Katyuri Style</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Dress Code
                                </p>
                                <p class="font-bold text-gray-800">Traditional / Modest</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Open
                                    Season</p>
                                <p id="modalSeason" class="font-bold text-gray-800">April - Nov</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Visiting
                                    Hours</p>
                                <p id="modalTiming" class="font-bold text-gray-800"></p>
                            </div>
                        </div>
                        <br>
                        <hr>

                        <div class="mb-4">
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">History</p>
                            <p id="modalHistory" class="text-gray-600 text-xs leading-relaxed"></p>
                        </div>

                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Festivals
                                </p>
                                <p id="modalFestivals" class="font-bold text-gray-800 text-xs"></p>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Amenities
                                </p>
                                <p id="modalAmenities" class="font-bold text-gray-800 text-xs"></p>
                            </div>
                        </div>

                        
                    </div>

                    <div class="flex gap-4 mt-8">
                        <button
                            class="flex-grow bg-[#D97706] hover:bg-orange-700 text-white py-4 rounded-2xl font-bold transition-all shadow-lg shadow-orange-200">
                            RESERVE DARSHAN SLOT
                        </button>
                        <a id="modalMapLink" href="#" target="_blank"
                            class="px-8 border border-gray-200 hover:bg-gray-50 rounded-2xl flex items-center justify-center gap-2 font-bold text-sm text-black no-underline">
                            <i class="fa-solid fa-compass"></i> MAP
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script src="/js/script.js">     </script>